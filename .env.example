# Supabase Configuration (obter em: https://app.supabase.com/project/[project-id]/settings/api)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Features
VITE_SUPABASE_REALTIME_ENABLED=true
VITE_SUPABASE_STORAGE_BUCKET=avatars
VITE_SUPABASE_SCHEMA=public
VITE_SUPABASE_SESSION_TIMEOUT=3600

# Gemini AI
GEMINI_API_KEY="your-gemini-api-key"

# App URL
APP_URL="http://localhost:5173"
