# ============================================================================
# SUPABASE CONFIGURATION - OBRIGATÓRIO PARA SINCRO EM TEMPO REAL
# ============================================================================
# Obtenha estes valores no Supabase Dashboard: Settings → API

# URL do seu projeto Supabase (ex: https://abcdefghijk.supabase.co)
VITE_SUPABASE_URL=

# Chave pública / Anon Key (copie de Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=

# Nome alternativo suportado pelo sistema (caso use VITE_SUPABASE_PUBLISHABLE_KEY):
VITE_SUPABASE_PUBLISHABLE_KEY=

# ============================================================================
# POSTGRES DATABASE CREDENTIALS (Opcional)
# ============================================================================
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=

# ============================================================================
# SUPABASE SECRETS (Apenas Server-Side / CLI)
# ============================================================================
SUPABASE_JWT_SECRET=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# GUIA DE CONFIGURAÇÃO DE AMBIENTE
# ============================================================================
# 1. Desenvolvimento Local:
#    Crie um arquivo chamado .env.local na raiz do projeto contendo:
#    VITE_SUPABASE_URL=https://seu-projeto.supabase.co
#    VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui
#
# 2. Deploy em Produção (Vercel / GitHub Pages / CI/CD):
#    Configure as variáveis VITE_SUPABASE_URL e VITE_SUPABASE_ANON_KEY
#    nas configurações do painel de deploy (Environment Variables).
#
# ⚠️ IMPORTANTE: Variáveis com prefixo VITE_ são embutidas durante o BUILD.
#    Sempre execute um novo build/deploy após atualizar as variáveis!

