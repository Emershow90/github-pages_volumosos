# ============================================================================
# SUPABASE CONFIGURATION - OBRIGATÓRIO PARA AMBIENTE ONLINE
# ============================================================================
# Obtenha esses valores em: https://supabase.com/dashboard → Settings → API

# URL do seu projeto Supabase (ex: https://abcdefghijk.supabase.co)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Anon Key do seu projeto Supabase (copie de Settings → API → Anon Key)
# ⚠️ IMPORTANTE: Use ANON KEY (não Service Role Key!)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alternativa suportada (se preferir usar este nome):
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# POSTGRES DATABASE CREDENTIALS (Opcional - para desenvolvimento)
# ============================================================================
POSTGRES_DATABASE=postgres
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=sua_senha_postgres
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/database
POSTGRES_URL=postgresql://user:password@localhost:5432/database
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/database
POSTGRES_USER=postgres

# ============================================================================
# SUPABASE SECRETS (Apenas para server-side, NÃO use em cliente)
# ============================================================================
SUPABASE_JWT_SECRET=sua_jwt_secret_super_secreto
SUPABASE_SECRET_KEY=seu_service_role_key_super_secreto
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key_super_secreto

# ============================================================================
# COMO USAR ESTE ARQUIVO
# ============================================================================
# 1. Copie este arquivo para .env.local (será ignorado pelo Git):
#    cp .env.example .env.local
#
# 2. Preencha com seus valores REAIS do Supabase
#
# 3. Reinicie o servidor de desenvolvimento:
#    npm run dev
#
# 4. Verificar no console do navegador se a mensagem mudou de:
#    "[Supabase Init Log] No VITE_SUPABASE_URL encontrado..."
#    para:
#    "[Supabase Init Log] Variáveis de ambiente carregadas com sucesso."
#
# ⚠️ NUNCA commite .env.local - Use apenas localmente!
# ⚠️ Em produção (Vercel/Lovable), configure via painel de Variáveis de Ambiente
