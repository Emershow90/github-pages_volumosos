# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Supabase URL (obtido no Dashboard > Settings > API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Supabase Anon Key (publishable key - segura para uso no frontend)
VITE_SUPABASE_ANON_KEY=sb_publishable_CgGDu_1Z6Bptd4mA3Ri33w_v0KuKcW7

# ============================================
# GEMINI AI CONFIGURATION
# ============================================
# AI Studio automatically injects this at runtime from user secrets
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ============================================
# APP CONFIGURATION
# ============================================
# The URL where this applet is hosted
APP_URL="MY_APP_URL"

# ============================================
# SUPABASE REAL-TIME CONFIGURATION (opcional)
# ============================================
# Habilita/desabilita Realtime subscriptions
VITE_SUPABASE_REALTIME_ENABLED=true

# ============================================
# SUPABASE STORAGE CONFIGURATION (opcional)
# ============================================
# Bucket para upload de arquivos
VITE_SUPABASE_STORAGE_BUCKET=avatars
